<a href="/" class="site-title sl-flex" aria-label="Engram home">
	<svg
		class="site-mark"
		width="36"
		height="41"
		viewBox="0 0 36 41"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		xmlns:xlink="http://www.w3.org/1999/xlink"
	>
		<rect width="36" height="41" fill="url(#pattern0_242_546)" />
		<defs>
			<pattern id="pattern0_242_546" patternContentUnits="objectBoundingBox" width="1" height="1">
				<use xlink:href="#image0_242_546" transform="matrix(0.00454545 0 0 0.00399113 0 -0.00687361)" />
			</pattern>
			<image
				id="image0_242_546"
				width="220"
				height="254"
				preserveAspectRatio="none"
				xlink:href="data:image/png;base64,"
			/>
		</defs>
	</svg>
	<span class="brand-wordmark" translate="no">engram</span>
</a>

<style>
	@layer starlight.core {
		.site-title {
			align-items: center;
			gap: 0.65rem;
			text-decoration: none;
			white-space: nowrap;
			min-width: 0;
		}

		.site-mark {
			height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
			width: auto;
			flex-shrink: 0;
		}

		.brand-wordmark {
			font-family: 'Geist', system-ui, sans-serif;
			font-size: 1.05rem;
			font-weight: 700;
			letter-spacing: -0.03em;
			color: var(--sl-color-white);
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.site-title:hover .brand-wordmark,
		.site-title:focus-visible .brand-wordmark {
			color: var(--engram-accent-high);
		}
	}
</style>