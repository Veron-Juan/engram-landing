<style>
  .agents {
    position: relative;
  }

  .agents__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .agents__header h2 {
    margin-top: 1rem;
    margin-bottom: 0.75rem;
  }

  .agents__sub {
    color: var(--text-secondary);
    font-size: 1.0625rem;
  }

  .agents__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .agents__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 1.5rem;
  }

  .agents__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    
    border-radius: 12px;
    margin-bottom: 0.5rem;
    position: relative;
  }

  .agents__card-icon::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 16px;
    
    filter: blur(6px);
    z-index: -1;
  }

  .agents__card-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .agents__card-desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .agents__card-cmd {
    margin-top: auto;
    padding: 0.35rem 0.65rem;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 6px;
    font-size: 0.7rem;
    width: 100%;
    overflow: hidden;
  }

  .agents__card-cmd code {
    font-family: var(--font-mono);
    color: var(--text-secondary);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
    display: block;
  }

  .agents__footer {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .agents__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .agents__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .agents__grid { grid-template-columns: 1fr; }
  }
</style>
