---
// Footer
---

<footer class="footer">
  <div class="divider"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Engram home">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="14" cy="14" r="13" stroke="#ea1889" stroke-width="1.5"/>
          <path d="M8 14 Q14 6 20 14 Q14 22 8 14Z" fill="#ea1889" opacity="0.9"/>
          <circle cx="14" cy="14" r="2.5" fill="#ea1889"/>
        </svg>
        <span>engram</span>
      </a>
      <p class="footer__tagline">Persistent memory for AI coding agents.</p>
      <p class="footer__credit">
        <span class="footer__dot" aria-hidden="true">/ˈen.ɡræm/</span>
        the physical trace of a memory in the brain.
      </p>
    </div>

    <nav class="footer__links" aria-label="Footer navigation">
      <div class="footer__col">
        <span class="footer__col-title">Product</span>
        <a href="/getting-started/" class="footer__link">Getting Started</a>
        <a href="/getting-started/installation/" class="footer__link">Installation</a>
        <a href="/agent-setup/" class="footer__link">Agent Setup</a>
        <a href="/features/" class="footer__link">Features</a>
      </div>
      <div class="footer__col">
        <span class="footer__col-title">Learn</span>
        <a href="/architecture/" class="footer__link">Architecture</a>
        <a href="/guides/" class="footer__link">Guides</a>
        <a href="/reference/" class="footer__link">Reference</a>
        <a href="/comparison/" class="footer__link">Comparison</a>
      </div>
      <div class="footer__col">
        <span class="footer__col-title">Contribute</span>
        <a href="https://github.com/Gentleman-Programming/engram" target="_blank" rel="noopener noreferrer" class="footer__link">GitHub</a>
        <a href="/contributing/" class="footer__link">Contributing</a>
        <a href="https://github.com/Gentleman-Programming/engram/issues" target="_blank" rel="noopener noreferrer" class="footer__link">Issues</a>
        <a href="https://github.com/Gentleman-Programming/engram/releases" target="_blank" rel="noopener noreferrer" class="footer__link">Changelog</a>
      </div>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p class="footer__legal">
      MIT License — &copy; {new Date().getFullYear()} Gentleman Programming
    </p>
    <p class="footer__legal footer__right">
      Inspired by <a href="https://github.com/thedotmack/claude-mem" target="_blank" rel="noopener noreferrer">claude-mem</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding-top: 0;
    padding-bottom: 2rem;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    padding-block: 3rem;
    align-items: start;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__logo:hover { opacity: 0.7; }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.35rem;
  }

  .footer__credit {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .footer__dot {
    color: var(--accent);
    margin-right: 0.25rem;
  }

  .footer__links {
    display: flex;
    gap: 3rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__col-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 0.25rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer__link:hover { color: var(--text-primary); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer__legal {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .footer__legal a {
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: color 0.2s;
    text-decoration: none;
  }

  .footer__legal a:hover { color: var(--text-secondary); }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__links {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  @media (max-width: 480px) {
    .footer__bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
