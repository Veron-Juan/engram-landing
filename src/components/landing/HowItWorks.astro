---
// How It Works — 3-step visual flow
---

<section class="how section" id="how-it-works">
  <div class="container">
    <div class="how__header reveal">
      <p class="eyebrow" data-i18n="how.eyebrow">How it works</p>
      <h2 class="display-lg">
        <span data-i18n="how.headline1">Three steps to a</span><br/>
        <span class="gradient-text" data-i18n="how.headline2">permanent memory.</span>
      </h2>
    </div>

    <div class="how__steps">

      <div class="how__step reveal">
        <div class="how__step-num" aria-hidden="true">01</div>
        <div class="how__step-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#ea1889" stroke-width="1.5" stroke-linecap="round">
            <path d="M14 2C8.48 2 4 6.48 4 12s4.48 10 10 10c5.52 0 10-4.48 10-10"/>
            <path d="M14 6v6l4 2"/>
            <path d="M20 4l4 2-2 4"/>
          </svg>
        </div>
        <h3 class="how__step-title" data-i18n="how.step1.title">Install once</h3>
        <p class="how__step-desc" data-i18n-html="how.step1.desc">
          One <code>brew install</code> command. Or download the binary directly for
          Windows and Mac/Linux. No runtime, no dependencies, no setup scripts.
        </p>
        <div class="how__step-command">
          <span class="hc-prompt">$</span>
          <code>brew install gentleman-programming/tap/engram</code>
        </div>
      </div>

      <div class="how__connector" aria-hidden="true">
        <div class="how__connector-line"></div>
        <svg class="how__connector-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 8h8M9 5l3 3-3 3" stroke="rgba(234,24,137,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="how__step reveal reveal-delay-2">
        <div class="how__step-num" aria-hidden="true">02</div>
        <div class="how__step-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#ea1889" stroke-width="1.5" stroke-linecap="round">
            <path d="M6 14h16"/>
            <path d="M6 8h10"/>
            <path d="M6 20h8"/>
            <circle cx="21" cy="19" r="4.5"/>
            <path d="M21 17v2l1.5 1.5"/>
          </svg>
        </div>
        <h3 class="how__step-title" data-i18n="how.step2.title">Agent save memory</h3>
        <p class="how__step-desc" data-i18n-html="how.step2.desc">
          You do nothing. Agents call <code>mem_save</code> for bugfixes,
          decisions, discoveries, and conventions automatically.
          Key moments stay ready for later.
        </p>
        <div class="how__step-command">
          <span class="hc-prompt">&gt;</span>
      
           
          <code>mem_save("Fixed N+1 query in UserList")</code>
        </div>
      </div>

      <div class="how__connector" aria-hidden="true">
        <div class="how__connector-line"></div>
        <svg class="how__connector-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 8h8M9 5l3 3-3 3" stroke="rgba(234,24,137,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="how__step reveal reveal-delay-4">
        <div class="how__step-num" aria-hidden="true">03</div>
        <div class="how__step-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="#ea1889" stroke-width="1.5" stroke-linecap="round">
            <path d="M14 4v8l5 3"/>
            <path d="M4.93 10.93A9 9 0 1 0 14 5"/>
          </svg>
        </div>
        <h3 class="how__step-title" data-i18n="how.step3.title">Next session: context loaded</h3>
        <p class="how__step-desc" data-i18n="how.step3.desc">
          Start a new session and your agent automatically searches past memories,
          resumes where you left off, and never asks you to re-explain the codebase.
        </p>
        <div class="how__step-command">
          <span class="hc-prompt">&gt;</span>
          <code>mem_context() → 24 memories loaded</code>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .how {
    position: relative;
    background: var(--bg-base);
  }

  .how__header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .how__header h2 {
    margin-top: 1rem;
  }

  .how__steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: start;
  }

  .how__step {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 18px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .how__step::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .how__step:hover {
    border-color: var(--border-glow);
    box-shadow: var(--shadow-glow);
  }

  .how__step:hover::before {
    opacity: 1;
  }

  .how__step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    opacity: 0.7;
  }

  .how__step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: rgba(234, 24, 137, 0.1);
    border-radius: 14px;
    margin-bottom: 1.25rem;
    position: relative;
  }

  .how__step-icon::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 20px;
    background: radial-gradient(ellipse, rgba(234, 24, 137, 0.3) 0%, transparent 70%);
    filter: blur(8px);
    z-index: -1;
  }

  .how__step-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .how__step-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .how__step-desc code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .how__step-command {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.775rem;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .hc-prompt { color: var(--accent); flex-shrink: 0; }

  .how__step-command code {
    font-family: var(--font-mono);
    font-size: 1em;
    color: var(--text-primary);
    background: none;
    padding: 0;
  }

  /* Connectors */
  .how__connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-inline: 0.5rem;
    padding-top: 4rem;
    gap: 0.25rem;
  }

  .how__connector-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgba(234, 24, 137, 0.4), transparent);
  }

  .how__connector-arrow {
    transform: rotate(90deg);
    margin-top: -4px;
  }

  @media (max-width: 900px) {
    .how__steps {
      grid-template-columns: 1fr;
    }

    .how__connector {
      padding: 0;
      flex-direction: row;
      height: 2rem;
    }

    .how__connector-line {
      width: 40px;
      height: 1px;
    }

    .how__connector-arrow {
      transform: none;
      margin-top: 0;
    }
  }
</style>
