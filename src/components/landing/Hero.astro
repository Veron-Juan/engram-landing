---
// Hero section — the flagship entrance
---

<section class="hero noise-overlay" id="hero">
  <!-- Radial glow orb -->
  <div class="hero__orb" aria-hidden="true"></div>
  <div class="hero__orb hero__orb--secondary" aria-hidden="true"></div>

  <!-- Grid texture -->
  <div class="hero__grid" aria-hidden="true"></div>

  <div class="hero__content container">
    <div class="hero__left reveal">
      <div class="hero__badge eyebrow reveal reveal-delay-1">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        Single binary &mdash; Zero dependencies
      </div>

      <h1 class="display-xl hero__headline reveal reveal-delay-2">
        Give your<br/>
        agent a<br/>
        <span class="gradient-text">brain.</span>
      </h1>

      <p class="hero__sub reveal reveal-delay-3">
        Persistent memory for AI coding agents. Agent-agnostic, SQLite + FTS5,
        a single Go binary. Works with Claude Code, Gemini CLI, Codex, VS Code and more.
      </p>

      <div class="hero__actions reveal reveal-delay-4">
        <a href="/getting-started/installation/" class="btn btn-primary btn-lg">
          Install Engram
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v10M3 7l5 5 5-5M1 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/getting-started/" class="btn btn-secondary btn-lg">
          Read the docs
        </a>
      </div>

      <div class="hero__install reveal reveal-delay-5">
        <div class="hero__install-bar">
          <span class="hero__install-prompt">$</span>
          <code class="hero__install-cmd">brew install gentleman-programming/tap/engram</code>
          <button class="hero__copy-btn" id="copy-install" aria-label="Copy install command">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M3 3V2a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M1 5h2M1 7h2M1 9h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
            </svg>
          </button>
        </div>
      </div>

      <p class="hero__platforms reveal reveal-delay-6">
        Also available for <a href="/getting-started/installation/">Windows &amp; Linux</a>
      </p>
    </div>

    <div class="hero__right reveal reveal-delay-2" aria-hidden="true">
        <img src="/test2.png"  width={90} />
      <div class="hero__terminal">
        <div class="hero__terminal-bar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="hero__terminal-title">engram tui</span>
        </div>
        <div class="hero__terminal-body">
          <div class="hero__terminal-line"><span class="term-dim">●</span> <span class="term-label">Last session</span> <span class="term-muted">4 minutes ago</span></div>
          <div class="hero__terminal-line"> </div>
          <div class="hero__terminal-line"><span class="term-idx">1</span> <span class="term-type type-bugfix">bugfix</span> Fixed N+1 query in UserList</div>
          <div class="hero__terminal-line"><span class="term-idx">2</span> <span class="term-type type-decision">decision</span> Migrate to Prisma ORM</div>
          <div class="hero__terminal-line"><span class="term-idx">3</span> <span class="term-type type-arch">architecture</span> Auth model uses JWT + refresh</div>
          <div class="hero__terminal-line"><span class="term-idx">4</span> <span class="term-type type-discovery">discovery</span> Rate limit is 100 req/min</div>
          <div class="hero__terminal-line"> </div>
          <div class="hero__terminal-line"><span class="term-dim">▶</span> <span class="term-muted">/ to search your memories...</span><span class="hero__cursor" aria-hidden="true">█</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    overflow: hidden;
    background: var(--bg-base);
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .hero__orb {
    width: clamp(400px, 50vw, 750px);
    height: clamp(400px, 50vw, 750px);
    top: -20%;
    right: -15%;
    background: radial-gradient(ellipse, rgba(234, 24, 137, 0.18) 0%, rgba(234, 24, 137, 0.04) 50%, transparent 70%);
  }

  .hero__orb--secondary {
    width: clamp(300px, 35vw, 500px);
    height: clamp(300px, 35vw, 500px);
    bottom: -10%;
    left: -10%;
    background: radial-gradient(ellipse, rgba(234, 24, 137, 0.09) 0%, transparent 65%);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-block: var(--section-py);
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    background: var(--accent-soft);
    border: 1px solid rgba(234, 24, 137, 0.25);
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent); }
    50% { opacity: 0.5; box-shadow: 0 0 3px var(--accent); }
  }

  .hero__headline {
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .hero__sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero__install {
    margin-bottom: 1rem;
  }

  .hero__install-bar {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    max-width: 100%;
    overflow: hidden;
  }

  .hero__install-prompt {
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero__install-cmd {
    color: var(--text-primary);
    font-family: var(--font-mono);
    background: none;
    font-size: 0.8125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hero__copy-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.15rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
  }

  .hero__copy-btn:hover {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .hero__platforms {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .hero__platforms a {
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255,255,255,0.15);
    transition: color 0.2s, border-color 0.2s;
  }

  .hero__platforms a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Terminal mockup */
  .hero__terminal {
    background: #0d0d10;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(0,0,0,0.5), var(--shadow-glow);
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 1.2vw, 0.875rem);
  }

  .hero__terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    background: #111114;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .hero__terminal-title {
    margin-left: auto;
    margin-right: auto;
    font-size: 0.75rem;
    color: #9595a8;
    font-family: var(--font-mono);
  }

  .hero__terminal-body {
    padding: 1.25rem 1.25rem 1.5rem;
    line-height: 1.9;
  }

  .hero__terminal-line {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 1.5em;
  }

  .term-dim { color: #52525b; }
  .term-label { color: var(--text-secondary); font-weight: 500; }
  .term-muted { color: #52525b; margin-left: auto; }
  .term-idx { color: #52525b; min-width: 1.2em; text-align: right; }

  .term-type {
    display: inline-block;
    padding: 0.1em 0.55em;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .type-bugfix { background: rgba(239, 68, 68, 0.15); color: #f87171; }
  .type-decision { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }
  .type-arch { background: rgba(234, 24, 137, 0.15); color: #ea1889; }
  .type-discovery { background: rgba(16, 185, 129, 0.15); color: #34d399; }

  .hero__cursor {
    display: inline-block;
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 900px) {
    .hero__content {
      grid-template-columns: 1fr;
    }

    .hero__right {
      display: none;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-install');
  const cmd = 'brew install gentleman-programming/tap/engram';

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(cmd);
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 8.5l3 3 7-7" stroke="#ea1889" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
    } catch {}
  });
</script>
