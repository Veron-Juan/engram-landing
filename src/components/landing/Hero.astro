---
// Hero section — the flagship entrance
---

<section class="hero noise-overlay" id="hero">
  <!-- Radial glow orb -->
  <div class="hero__orb" aria-hidden="true"></div>
  <div class="hero__orb hero__orb--secondary" aria-hidden="true"></div>

  <!-- Grid texture -->
  <div class="hero__grid" aria-hidden="true"></div>

  <div class="hero__content container">
    <div class="hero__left reveal">
      <div class="hero__badge eyebrow reveal reveal-delay-1">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        Single binary &mdash; Zero dependencies
      </div>

      <h1 class="display-xl hero__headline reveal reveal-delay-2">
        Give your agent a<br/>
        <span class="gradient-text">brain.</span>
      </h1>

      <p class="hero__sub reveal reveal-delay-3">
        Persistent memory for AI coding agents. Agent-agnostic, SQLite + FTS5,
        a single Go binary. Works with Claude Code, Gemini CLI, Codex, VS Code and more.
      </p>

      <div class="hero__actions reveal reveal-delay-4">
        <a href="/getting-started/installation/" class="btn btn-primary btn-lg">
          Install Engram
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v10M3 7l5 5 5-5M1 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/getting-started/" class="btn btn-secondary btn-lg">
          Read the docs
        </a>
      </div>

      <div class="hero__install reveal reveal-delay-5">
        <div class="hero__install-bar">
          <span class="hero__install-prompt">$</span>
          <code class="hero__install-cmd">brew install gentleman-programming/tap/engram</code>
          <button class="hero__copy-btn" id="copy-install" aria-label="Copy install command">
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M3 3V2a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M1 5h2M1 7h2M1 9h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
            </svg>
          </button>
        </div>
      </div>

      <p class="hero__platforms reveal reveal-delay-6">
        Also available for <a href="/getting-started/installation/">Windows &amp; Mac/Linux</a>
      </p>

      <div class="hero__terminal reveal reveal-delay-6" aria-hidden="true">
        <div class="hero__terminal-bar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="hero__terminal-title">engram tui</span>
        </div>
        <div class="hero__terminal-body">
          <div class="hero__terminal-screen">
            <div class="hero__terminal-heading">engram - Persistent Memory for AI Agents</div>
            <div class="hero__terminal-rule"></div>

           

            <div class="hero__terminal-projects">
              <span class="term-label">Projects:</span>
              <span class="hero__terminal-project-list">engram, client-api, landing-engram</span>
            </div>

            <div class="hero__terminal-section-title">Recent observations - 3 total</div>

            <div class="hero__terminal-list">
              <div class="hero__terminal-list-row hero__terminal-list-row--active">
                <span class="hero__terminal-caret">▸</span>
                <span class="hero__terminal-id">#118</span>
                <span class="hero__terminal-tag hero__terminal-tag--architecture">[architecture]</span>
                <span class="hero__terminal-entry">Refined sync boundary for memory export</span>
              </div>
              <div class="hero__terminal-list-row hero__terminal-list-row--detail">
                <span class="hero__terminal-indent"></span>
                <span class="hero__terminal-detail"><strong>What</strong>: consolidated chunk writes and reduced duplicate export passes...</span>
              </div>

              <div class="hero__terminal-list-row">
                <span class="hero__terminal-indent"></span>
                <span class="hero__terminal-id">#117</span>
                <span class="hero__terminal-tag hero__terminal-tag--bugfix">[bugfix]</span>
                <span class="hero__terminal-entry">Fixed broken session resume after compaction</span>
              </div>

              <div class="hero__terminal-list-row">
                <span class="hero__terminal-indent"></span>
                <span class="hero__terminal-id">#116</span>
                <span class="hero__terminal-tag hero__terminal-tag--decision">[decision]</span>
                <span class="hero__terminal-entry">Use topic keys for evolving project memories</span>
              </div>
            </div>

            <div class="hero__terminal-footer">
              <span>j/k navigate</span>
              <span class="term-dim">•</span>
              <span>enter select</span>
              <span class="term-dim">•</span>
              <span>/ search</span>
              <span class="term-dim">•</span>
              <span>q quit</span>
              <span class="hero__cursor" aria-hidden="true">█</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 3rem;
    overflow: hidden;
    background: var(--bg-base);
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .hero__orb {
    width: clamp(400px, 50vw, 750px);
    height: clamp(400px, 50vw, 750px);
    top: -20%;
    right: -15%;
    background: radial-gradient(ellipse, rgba(234, 24, 137, 0.18) 0%, rgba(234, 24, 137, 0.04) 50%, transparent 70%);
  }

  .hero__orb--secondary {
    width: clamp(300px, 35vw, 500px);
    height: clamp(300px, 35vw, 500px);
    bottom: -10%;
    left: -10%;
    background: radial-gradient(ellipse, rgba(234, 24, 137, 0.09) 0%, transparent 65%);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-block: var(--section-py);
    text-align: center;
    
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    background: var(--accent-soft);
    border: 1px solid rgba(234, 24, 137, 0.25);
    border-radius: 999px;
    margin-bottom: 1.5rem;
    
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent); }
    50% { opacity: 0.5; box-shadow: 0 0 3px var(--accent); }
  }

  .hero__headline {
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    text-align: center;
    width: 100%;
    
  }

  .hero__sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    
    text-align: center;
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    
  }

  .hero__install {
    margin-bottom: 1rem;
  }

  .hero__install-bar {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    max-width: 100%;
    overflow: hidden;
    
  }

  .hero__install-prompt {
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero__install-cmd {
    color: var(--text-primary);
    font-family: var(--font-mono);
    background: none;
    font-size: 0.8125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hero__copy-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.15rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
  }

  .hero__copy-btn:hover {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .hero__platforms {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .hero__platforms a {
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255,255,255,0.15);
    transition: color 0.2s, border-color 0.2s;
  }

  .hero__platforms a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Terminal mockup */
  .hero__terminal {
    margin-top: 3rem;
    width: 100%;
    max-width: 680px;
    background: #0d0d10;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(0,0,0,0.5), var(--shadow-glow);
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1vw, 0.8rem);
  }

  .hero__terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: clamp(0.5rem, 0.7vw, 0.7rem) clamp(0.8rem, 1vw, 1rem);
    background: #111114;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .hero__terminal-title {
    margin-left: auto;
    margin-right: auto;
    font-size: 0.75rem;
    color: #9595a8;
    font-family: var(--font-mono);
  }

  .hero__terminal-body {
    padding: clamp(0.8rem, 1.5vw, 1.4rem) clamp(0.9rem, 1.8vw, 1.5rem);
    line-height: 1.55;
    background:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,0.035), transparent 16%),
      radial-gradient(circle at 82% 74%, rgba(255,255,255,0.025), transparent 20%),
      radial-gradient(circle at 58% 24%, rgba(255,255,255,0.018), transparent 16%),
      #09090b;
  }

  .hero__terminal-screen {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 0.8vw, 1rem);
    /* min-height: 430px; */
    color: #c4c4d8;
  }

  .hero__terminal-heading {
    color: #fafafa;
    font-size: clamp(0.78rem, 1.1vw, 0.95rem);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .hero__terminal-rule {
    width: 74%;
    height: 1px;
    background: rgba(234, 24, 137, 0.35);
  }

  .hero__terminal-stats-box {
    width: 68%;
    margin-top: 0.5rem;
    padding: 1.35rem 1.45rem;
    border: 1px solid rgba(188, 195, 255, 0.32);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .hero__terminal-stat-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: baseline;
    line-height: 1.45;
  }

  .hero__terminal-stat-value {
    color: #a8e4a0;
    font-weight: 700;
    font-size: 1rem;
    text-align: right;
  }

  .hero__terminal-stat-label {
    color: #d6dbff;
    font-size: 0.95rem;
  }

  .hero__terminal-projects {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    flex-wrap: wrap;
    font-size: 0.92rem;
  }

  .hero__terminal-project-list {
    color: #f7a8d4;
  }

  .hero__terminal-section-title {
    color: #ea1889;
    font-weight: 700;
    font-size: clamp(0.78rem, 1.1vw, 0.95rem);
    margin-top: 0.35rem;
  }

  .hero__terminal-list {
    display: flex;
    flex-direction: column;
    gap: clamp(0.2rem, 0.3vw, 0.35rem);
  }

  .hero__terminal-list-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: #c4c4d8;
    font-size: clamp(0.72rem, 0.9vw, 0.88rem);
    white-space: nowrap;
    overflow: hidden;
  }

  .hero__terminal-list-row--active {
    color: #fafafa;
    font-weight: 700;
  }

  .hero__terminal-list-row--detail {
    color: #8080a0;
    padding-left: 1.2rem;
    font-size: clamp(0.68rem, 0.82vw, 0.83rem);
  }

  .hero__terminal-caret {
    color: #ffffff;
    width: 0.8rem;
    flex-shrink: 0;
  }

  .hero__terminal-indent {
    width: 0.8rem;
    flex-shrink: 0;
  }

  .hero__terminal-id {
    color: #a1a1aa;
    min-width: 2.6rem;
    flex-shrink: 0;
  }

  .hero__terminal-tag {
    flex-shrink: 0;
    font-weight: 700;
  }

  .hero__terminal-tag--architecture {
    color: #fb923c;
  }

  .hero__terminal-tag--bugfix {
    color: #f87171;
  }

  .hero__terminal-tag--decision {
    color: #fbbf24;
  }

  .hero__terminal-entry,
  .hero__terminal-detail {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hero__terminal-entry {
    color: #e4e4f0;
  }

  .hero__terminal-detail strong {
    color: #e4e4f0;
    font-weight: 700;
  }

  .hero__terminal-footer {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: #52525b;
    font-size: clamp(0.68rem, 0.82vw, 0.82rem);
  }

  .term-dim { color: #3e3e58; }
  .term-label { color: var(--text-secondary); font-weight: 500; }

  .hero__cursor {
    display: inline-block;
    color: #ea1889;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 900px) {
    .hero__terminal {
      max-width: 100%;
      max-height: 260px;
      overflow: hidden;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-install');
  const cmd = 'brew install gentleman-programming/tap/engram';

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(cmd);
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M2.5 8.5l3 3 7-7" stroke="#ea1889" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
    } catch {}
  });
</script>
