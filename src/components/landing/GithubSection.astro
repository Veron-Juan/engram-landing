---
// GitHub / Open Source section — fetches real data at build time
const REPO = 'Gentleman-Programming/engram';
const API_BASE = 'https://api.github.com';

// Fallback values (update manually if needed — used when API is rate-limited or unavailable)
const FALLBACK = {
  stars: 2368,
  forks: 253,
  contributors: [
    { login: 'Alan-TheGentleman', avatar_url: 'https://avatars.githubusercontent.com/u/6935240?v=4', html_url: 'https://github.com/Alan-TheGentleman', contributions: 134 },
    { login: 'Twinber',           avatar_url: 'https://avatars.githubusercontent.com/u/5513621?v=4',  html_url: 'https://github.com/Twinber',           contributions: 3 },
    { login: 'SantiagoBobrik',    avatar_url: 'https://avatars.githubusercontent.com/u/43079605?v=4', html_url: 'https://github.com/SantiagoBobrik',    contributions: 2 },
    { login: 'sanurb',            avatar_url: 'https://avatars.githubusercontent.com/u/60886336?v=4', html_url: 'https://github.com/sanurb',            contributions: 2 },
    { login: 'avirgili-eclub',    avatar_url: 'https://avatars.githubusercontent.com/u/108747635?v=4',html_url: 'https://github.com/avirgili-eclub',    contributions: 2 },
    { login: 'alaslibress',       avatar_url: 'https://avatars.githubusercontent.com/u/185132130?v=4',html_url: 'https://github.com/alaslibress',       contributions: 1 },
    { login: 'bmunoz89',          avatar_url: 'https://avatars.githubusercontent.com/u/1822983?v=4',  html_url: 'https://github.com/bmunoz89',          contributions: 1 },
    { login: 'chrux',             avatar_url: 'https://avatars.githubusercontent.com/u/610949?v=4',   html_url: 'https://github.com/chrux',             contributions: 1 },
    { login: 'pascencio',         avatar_url: 'https://avatars.githubusercontent.com/u/9783678?v=4',  html_url: 'https://github.com/pascencio',         contributions: 1 },
    { login: 'd4rw1nC4C',         avatar_url: 'https://avatars.githubusercontent.com/u/223385542?v=4',html_url: 'https://github.com/d4rw1nC4C',         contributions: 1 },
    { login: 'jalfarocode',       avatar_url: 'https://avatars.githubusercontent.com/u/249999384?v=4',html_url: 'https://github.com/jalfarocode',       contributions: 1 },
    { login: 'TESTPERSONAL',      avatar_url: 'https://avatars.githubusercontent.com/u/6664588?v=4',  html_url: 'https://github.com/TESTPERSONAL',      contributions: 1 },
  ],
};

interface RepoData {
  stargazers_count: number;
  forks_count: number;
}

interface Contributor {
  login: string;
  avatar_url: string;
  html_url: string;
  contributions: number;
}

let stars = FALLBACK.stars;
let forks = FALLBACK.forks;
let contributors: Contributor[] = FALLBACK.contributors;

// Build auth headers — use GITHUB_TOKEN if available for 5000 req/hour instead of 60
const token = import.meta.env.GITHUB_TOKEN;
const headers: Record<string, string> = {
  'Accept': 'application/vnd.github.v3+json',
  'User-Agent': 'engram-landing',
};
if (token) headers['Authorization'] = `Bearer ${token}`;

try {
  const [repoRes, contribRes] = await Promise.all([
    fetch(`${API_BASE}/repos/${REPO}`, { headers }),
    fetch(`${API_BASE}/repos/${REPO}/contributors?per_page=50`, { headers }),
  ]);

  if (repoRes.ok) {
    const repo: RepoData = await repoRes.json();
    stars = repo.stargazers_count;
    forks = repo.forks_count;
  }

  if (contribRes.ok) {
    const data: Contributor[] = await contribRes.json();
    if (data.length > 0) contributors = data;
  }
} catch {
  // Network error — fallback values already set above
}

function formatNumber(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k`;
  return n.toString();
}

const contributorCount = contributors.length;
---

<section class="github section" id="open-source">
  <div class="container">

    <!-- Header -->
    <div class="github__header reveal">
      <p class="eyebrow">Open Source</p>
      <h2 class="display-lg">
        Built in public.<br/>
        <span class="gradient-text">Open for everyone.</span>
      </h2>
      <p class="github__subtitle">
        Engram is MIT licensed and actively maintained. Every decision is made
        in the open — audit the code, open an issue, or submit a PR.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="github__stats-bar reveal reveal-delay-1">
      <a href={`https://github.com/${REPO}/stargazers`} target="_blank" rel="noopener noreferrer" class="github__stat-pill">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M8 1L10 5.5H15L11 8.5L12.5 13L8 10L3.5 13L5 8.5L1 5.5H6Z"/>
        </svg>
        <span>{formatNumber(stars)}</span>
        <span>Stars</span>
      </a>
      <a href={`https://github.com/${REPO}/forks`} target="_blank" rel="noopener noreferrer" class="github__stat-pill">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="5" cy="3" r="2"/>
          <circle cx="11" cy="3" r="2"/>
          <circle cx="8" cy="12" r="2"/>
          <path d="M5 5v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2V5"/>
          <path d="M8 10v2"/>
        </svg>
        <span>{formatNumber(forks)}</span>
        <span>Forks</span>
      </a>
      <div class="github__stat-pill">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="8" cy="5" r="3"/>
          <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
        </svg>
        <span>{contributorCount}</span>
        <span>Contributors</span>
      </div>
      <div class="github__stat-pill">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <circle cx="8" cy="8" r="7"/>
          <circle cx="8" cy="8" r="2.5"/>
        </svg>
        <span>MIT</span>
        <span>License</span>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="github__inner">

      <!-- Left: Contributors showcase -->
      <div class="github__left reveal reveal-delay-2">

        <!-- Avatar stack (overlapping circles) -->
        <div class="github__avatar-stack">
          {contributors.slice(0, 8).map((c, i) => (
            <a
              href={c.html_url}
              target="_blank"
              rel="noopener noreferrer"
              class="github__avatar-link"
              title={`@${c.login}`}
              style={`z-index: ${contributors.length - i}`}
            >
              <img
                src={`${c.avatar_url}&s=80`}
                alt={`@${c.login}`}
                width="44"
                height="44"
                loading="lazy"
                decoding="async"
              />
            </a>
          ))}
          {contributors.length > 8 && (
            <a
              href={`https://github.com/${REPO}/graphs/contributors`}
              target="_blank"
              rel="noopener noreferrer"
              class="github__avatar-more"
            >
              +{contributors.length - 8}
            </a>
          )}
        </div>

        <!-- Contributor list -->
        <div class="github__contributors-card">
          <div class="github__contributors-card-header">
            <span class="github__contributors-label">Contributors</span>
            <div class="github__badge-active">
              <span class="github__dot-live" aria-hidden="true"></span>
              Actively maintained
            </div>
          </div>

          <div class="github__contributors-list">
            {contributors.map((c) => (
              <a
                href={c.html_url}
                target="_blank"
                rel="noopener noreferrer"
                class="github__person"
                title={`@${c.login}`}
              >
                <img
                  src={`${c.avatar_url}&s=64`}
                  alt={`@${c.login}`}
                  width="36"
                  height="36"
                  loading="lazy"
                  decoding="async"
                />
                <span class="github__person-name">@{c.login}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Repo card + CTAs -->
      <div class="github__right reveal reveal-delay-3">
        <div class="github__repo-card">
          <div class="github__repo-header">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="var(--accent)" aria-hidden="true">
              <path d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33C3.72 14.68 3.26 13 3.26 13c-.37-.93-.9-1.17-.9-1.17-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.67 7.67 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.14.46.55.38A8 8 0 0 0 8 .25z"/>
            </svg>
            <span>Gentleman-Programming / engram</span>
          </div>

          <div class="github__repo-body">
            <h4 class="github__how-title">How to contribute</h4>
            <ol class="github__steps">
              <li>Fork the repository</li>
              <li>Create a feature branch</li>
              <li>Open a Pull Request</li>
            </ol>
          </div>

          <div class="github__repo-actions">
            <a href={`https://github.com/${REPO}`} target="_blank" rel="noopener noreferrer" class="btn btn-primary github__repo-btn">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33C3.72 14.68 3.26 13 3.26 13c-.37-.93-.9-1.17-.9-1.17-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.67 7.67 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.14.46.55.38A8 8 0 0 0 8 .25z"/>
              </svg>
              Star on GitHub
            </a>
            <a href={`https://github.com/${REPO}/pulls`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary github__repo-btn">
              Submit a PR
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M2 6.5h9M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="github__quick-links">
          <a href={`https://github.com/${REPO}/issues`} target="_blank" rel="noopener noreferrer" class="github__qlink">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="8" cy="8" r="7"/>
              <circle cx="8" cy="8" r="1.5" fill="currentColor"/>
            </svg>
            Open Issues
          </a>
          <a href={`https://github.com/${REPO}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener noreferrer" class="github__qlink">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 13V3h7l3 3v7a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/>
              <path d="M10 3v3h3"/>
            </svg>
            How to contribute →
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  /* ===== Section glow ===== */
  .github {
    position: relative;
  }

  .github::before {
    content: '';
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(234,24,137,0.05) 0%, transparent 55%);
    pointer-events: none;
    filter: blur(80px);
  }

  /* ===== Header ===== */
  .github__header {
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .github__header .eyebrow { margin-bottom: 0.75rem; }
  .github__header h2 { margin-bottom: 1.25rem; }

  .github__subtitle {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  /* ===== Stats bar ===== */
  .github__stats-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    flex-wrap: wrap;
  }

  .github__stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
  }

  .github__stat-pill strong {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .github__stat-pill span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .github__stat-pill svg {
    opacity: 0.5;
    flex-shrink: 0;
  }

  a.github__stat-pill:hover {
    border-color: var(--border-glow);
    background: var(--bg-elevated);
    box-shadow: 0 0 24px rgba(234,24,137,0.1);
    transform: translateY(-2px);
  }

  a.github__stat-pill:hover svg {
    opacity: 1;
    stroke: var(--accent);
  }

  /* ===== Two-column layout ===== */
  .github__inner {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  /* ===== Left column ===== */
  .github__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ===== Avatar stack (overlapping) ===== */
  .github__avatar-stack {
    display: flex;
    align-items: center;
    padding-left: 0.25rem;
  }

  .github__avatar-link {
    display: block;
    margin-left: -10px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .github__avatar-link:first-child {
    margin-left: 0;
  }

  .github__avatar-link:hover {
    transform: translateY(-4px) scale(1.12);
    z-index: 100 !important;
  }

  .github__avatar-link img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 3px solid var(--bg-base);
    object-fit: cover;
    transition: border-color 0.2s, box-shadow 0.2s;
    display: block;
  }

  .github__avatar-link:hover img {
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(234,24,137,0.35);
  }

  .github__avatar-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg-elevated);
    border: 3px solid var(--bg-base);
    margin-left: -10px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .github__avatar-more:hover {
    background: var(--accent-soft);
    color: var(--accent);
    transform: translateY(-4px) scale(1.12);
    border-color: var(--accent);
  }

  /* ===== Contributors card ===== */
  .github__contributors-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .github__contributors-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at top left, rgba(234,24,137,0.03) 0%, transparent 50%);
    pointer-events: none;
  }

  .github__contributors-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
  }

  .github__contributors-label {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .github__badge-active {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: #34d399;
    background: rgba(52,211,153,0.07);
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
    border: 1px solid rgba(52,211,153,0.12);
  }

  .github__dot-live {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }

  /* ===== Contributors list ===== */
  .github__contributors-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2px;
    padding: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .github__person {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 10px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .github__person:hover {
    background: var(--bg-elevated);
    transform: translateX(4px);
  }

  .github__person:hover img {
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(234,24,137,0.2);
  }

  .github__person img {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--border-subtle);
    flex-shrink: 0;
    object-fit: cover;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .github__person-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ===== Right column — repo card ===== */
  .github__right {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .github__repo-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .github__repo-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--accent) 50%, transparent 100%);
    opacity: 0.5;
  }

  .github__repo-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .github__repo-body {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .github__how-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .github__steps {
    list-style: none;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .github__steps li {
    counter-increment: steps;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .github__steps li::before {
    content: counter(steps);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .github__repo-actions {
    display: flex;
    gap: 0.5rem;
    padding: 1.25rem;
  }

  .github__repo-btn {
    flex: 1;
    justify-content: center;
    font-size: 0.85rem;
    padding: 0.65rem 1rem;
  }

  /* ===== Quick links ===== */
  .github__quick-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .github__qlink {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    font-size: 0.8125rem;
    font-family: var(--font-body);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .github__qlink:hover {
    border-color: rgba(234, 24, 137, 0.3);
    color: var(--text-primary);
    background: var(--bg-elevated);
    transform: translateX(4px);
  }

