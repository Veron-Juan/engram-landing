---
// GitHub / Open Source section
---

<section class="github section" id="open-source">
  <div class="container">
    <div class="github__inner">

      <div class="github__text reveal">
        <p class="eyebrow">Open Source</p>
        <h2 class="display-lg">
          Built in public.<br/>
          <span class="gradient-text">Open for everyone.</span>
        </h2>
        <p class="github__body">
          Engram is MIT licensed and actively maintained. Every decision is made
          in the open. Come audit the code, open an issue, or submit a PR.
          The project lives and grows with its community.
        </p>

        <div class="github__ctas">
          <a href="https://github.com/Gentleman-Programming/engram" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33C3.72 14.68 3.26 13 3.26 13c-.37-.93-.9-1.17-.9-1.17-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.67 7.67 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.14.46.55.38A8 8 0 0 0 8 .25z"/>
            </svg>
            Star on GitHub
          </a>
          <a href="https://github.com/Gentleman-Programming/engram/issues" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            Open Issues
          </a>
          <a href="https://github.com/Gentleman-Programming/engram/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
            How to contribute →
          </a>
        </div>
      </div>

      <div class="github__stats reveal reveal-delay-2">
        <div class="github__card">
          <div class="github__card-header">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="#ea1889" aria-hidden="true">
              <path d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33C3.72 14.68 3.26 13 3.26 13c-.37-.93-.9-1.17-.9-1.17-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.67 7.67 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.14.46.55.38A8 8 0 0 0 8 .25z"/>
            </svg>
            <span>Gentleman-Programming / engram</span>
          </div>

          <div class="github__metrics">
            <div class="github__metric">
              <div class="github__metric-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <path d="M8 1L10 5.5H15L11 8.5L12.5 13L8 10L3.5 13L5 8.5L1 5.5H6Z"/>
                </svg>
              </div>
              <div class="github__metric-value">Stars</div>
              <div class="github__metric-badge">GitHub</div>
            </div>

            <div class="github__metric">
              <div class="github__metric-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="5" cy="3" r="2"/>
                  <circle cx="11" cy="3" r="2"/>
                  <circle cx="8" cy="12" r="2"/>
                  <path d="M5 5v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2V5"/>
                  <path d="M8 10v2"/>
                </svg>
              </div>
              <div class="github__metric-value">Forks</div>
              <div class="github__metric-badge">GitHub</div>
            </div>

            <div class="github__metric">
              <div class="github__metric-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="8" cy="8" r="7"/>
                  <circle cx="8" cy="8" r="2.5"/>
                </svg>
              </div>
              <div class="github__metric-value">MIT</div>
              <div class="github__metric-badge">License</div>
            </div>

            <div class="github__metric">
              <div class="github__metric-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="4" cy="8" r="2.5"/>
                  <circle cx="12" cy="4" r="2.5"/>
                  <circle cx="12" cy="12" r="2.5"/>
                  <path d="M6.5 7l3-2M6.5 9l3 2"/>
                </svg>
              </div>
              <div class="github__metric-value">Go</div>
              <div class="github__metric-badge">Language</div>
            </div>
          </div>

          <div class="github__activity">
            <div class="github__activity-dot" aria-hidden="true"></div>
            <span>Actively maintained</span>
          </div>

          <div class="github__contribute">
            <h4 class="github__contribute-title">How to contribute</h4>
            <ol class="github__steps">
              <li>Fork the repository</li>
              <li>Create a feature branch</li>
              <li>Open a Pull Request</li>
            </ol>
            <a href="https://github.com/Gentleman-Programming/engram/pulls" target="_blank" rel="noopener noreferrer" class="btn btn-secondary github__pr-btn">
              Submit a PR
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M2 6.5h9M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .github {
    position: relative;
  }

  .github::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(234,24,137,0.06) 0%, transparent 65%);
    pointer-events: none;
    filter: blur(40px);
  }

  .github__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
  }

  .github__text .eyebrow { margin-bottom: 0.75rem; }

  .github__text h2 {
    margin-bottom: 1.25rem;
  }

  .github__body {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .github__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  /* GitHub card */
  .github__card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    overflow: hidden;
  }

  .github__card-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 1.25rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .github__metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .github__metric {
    background: var(--bg-surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0.75rem;
    gap: 0.4rem;
    transition: background 0.2s;
    text-align: center;
  }

  .github__metric:hover {
    background: var(--bg-elevated);
  }

  .github__metric-icon {
    color: var(--accent);
    opacity: 0.8;
  }

  .github__metric-value {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .github__metric-badge {
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .github__activity {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 0.8125rem;
    color: #34d399;
  }

  .github__activity-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .github__contribute {
    padding: 1.25rem;
  }

  .github__contribute-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .github__steps {
    list-style: none;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .github__steps li {
    counter-increment: steps;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .github__steps li::before {
    content: counter(steps);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .github__pr-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.875rem;
    padding: 0.65rem 1rem;
  }

  @media (max-width: 900px) {
    .github__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
